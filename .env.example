PORT=3000
DATABASE_PATH=./data/worldcup.db
ADMIN_REFRESH_SECRET=change-me
CRON_SECRET=

# Vercel/Neon production database. When set, the app uses Postgres instead of
# local SQLite.
DATABASE_URL=

# Optional: point this at an official FIFA JSON endpoint if/when available.
# The app keeps the integration isolated in src/fifa.js so the endpoint can be
# changed without touching UI or cache logic.
FIFA_MATCHES_URL=https://api.fifa.com/api/v3/calendar/matches?language=zh&count=500&idCompetition=17&idSeason=285023

# Optional: OpenAI-compatible chat completions provider. When AI_API_KEY is
# missing, refresh uses a deterministic local fallback so the project remains
# runnable.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
